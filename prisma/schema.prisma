generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum PermissionAction {
  VIEW
  CREATE
  UPDATE
  DELETE
  APPROVE
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
}

/// MES role a warehouse-scoped user is specialized in. Only meaningful when the user
/// is expected to act on manufacturing-floor resources (see User.mfgRole).
enum MfgRole {
  PRODUCTION_MANAGER
  PHOI
  HAN
  SON
  KCS
  WEAVING_MANAGER
  WEAVING_EXPORT
  BOM_MANAGER
  SPEC_STEEL
  SPEC_WIRE_PAINT
  SPEC_ACCESSORY
  SPEC_PACKAGING
}

/// Phôi (billet) sub-operation a user is responsible for. Only meaningful when
/// User.mfgRole = PHOI.
enum PhoiOperation {
  CAT
  TOP_DAU
  UON
  DAP
  DUC_LO
  BAN_TAN
}

enum NotificationAudience {
  ALL
  BOSS
  WAREHOUSE_STAFF
}

model User {
  id        String    @id @default(uuid())
  email     String    @unique
  password  String
  firstName String
  lastName  String
  isActive  Boolean   @default(true)
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  /// Business-attribute columns (not permission columns - see PermissionsGuard/RBAC
  /// above for actual authorization). Used for row-level scoping and MES-specific
  /// guards (@RequireMfgRole/@RequireWarehouseScope) layered on top of PermissionsGuard.
  mfgRole          MfgRole?
  phoiOperation    PhoiOperation?
  warehouseScope   String?
  isPurchaser      Boolean        @default(false)
  isProductPlanner Boolean        @default(false)
  isSale           Boolean        @default(false)

  roles             UserRole[]
  refreshTokens     RefreshToken[]
  notifications     Notification[]
  notificationReads NotificationRead[]

  @@index([deletedAt])
  @@index([warehouseScope])
  @@map("users")
}

model Role {
  id          String    @id @default(uuid())
  name        String    @unique
  description String?
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  users       UserRole[]
  permissions RolePermission[]

  @@index([deletedAt])
  @@map("roles")
}

model Permission {
  id          String           @id @default(uuid())
  module      String
  action      PermissionAction
  description String?
  createdAt   DateTime         @default(now())

  roles RolePermission[]

  @@unique([module, action])
  @@index([module])
  @@map("permissions")
}

model UserRole {
  userId     String
  roleId     String
  assignedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("user_roles")
}

model RolePermission {
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

/// Refresh tokens are stored hashed; supports rotation, revocation and logout.
/// The `expiresAt > createdAt` invariant is enforced at the DB level, see prisma/sql/001_add_check_constraints.sql
model RefreshToken {
  id                String    @id @default(uuid())
  userId            String
  tokenHash         String    @unique
  expiresAt         DateTime
  revokedAt         DateTime?
  replacedByTokenId String?
  createdByIp       String?
  revokedByIp       String?
  createdAt         DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

/// Written by the audit-log Prisma Client Extension (src/prisma/extensions/audit-log.extension.ts)
/// for every create/update/delete on a tracked model.
model AuditLog {
  id            String      @id @default(uuid())
  userId        String?
  action        AuditAction
  tableName     String
  recordId      String
  oldValue      Json?
  newValue      Json?
  ipAddress     String?
  correlationId String?
  createdAt     DateTime    @default(now())

  @@index([tableName, recordId])
  @@index([userId])
  @@map("audit_logs")
}

/// Admin broadcast, targeted by audience rather than individual recipients.
/// Per-user read state lives in NotificationRead.
model Notification {
  id        String               @id @default(uuid())
  title     String
  message   String
  audience  NotificationAudience
  createdBy String?
  createdAt DateTime             @default(now())

  creator User?              @relation(fields: [createdBy], references: [id], onDelete: SetNull)
  reads   NotificationRead[]

  @@index([audience])
  @@map("notifications")
}

/// Junction recording which users have read which notification. Composite PK
/// doubles as the upsert target that makes POST /notifications/:id/read idempotent.
model NotificationRead {
  notificationId String
  userId         String
  readAt         DateTime @default(now())

  notification Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([notificationId, userId])
  @@map("notification_reads")
}

/// Singleton row (id is pinned to 1 by a CHECK constraint, see
/// prisma/migrations/.../migration.sql) holding company-wide configuration.
/// Seeded once; there is intentionally no "create" endpoint.
model SystemConfig {
  id              Int      @id @default(1)
  companyName     String
  companyAddress  String?
  companyPhone    String?
  companyEmail    String?
  taxCode         String?
  defaultCurrency String   @default("VND")
  updatedAt       DateTime @updatedAt

  @@map("system_config")
}
